<Window x:Class="MVVM_Project1.View.User_Login"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MVVM_Project1.View"
        mc:Ignorable="d"
        Title="User_Login" Height="550" Width="800" 
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterScreen"
        MouseDown="Window_MouseDown"
        Background="Transparent"
        AllowsTransparency="True">
    <Border CornerRadius="10">
        <Border.Background>
            <ImageBrush ImageSource="C:\Users\tumay\Downloads\glowing-abstract-banner-with-red-blue-lights\22001.jpg" />
            
        </Border.Background>
        
    
    <Border CornerRadius="10"
            BorderThickness="3"
            Opacity="0.90">
        <Border.BorderBrush>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="LightGray" Offset="0.0" />
                <GradientStop Color="Black" Offset="0.75" />
                <GradientStop Color="Gray" Offset="1.0" />
            </LinearGradientBrush>
        </Border.BorderBrush>
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="Black" Offset="0.10" />
            </LinearGradientBrush>
        </Border.Background>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="30" />
                    <RowDefinition />
                </Grid.RowDefinitions>
                <Rectangle Grid.Row="0" Fill="White" Opacity="0.50" />

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition Width="25" />
                        <ColumnDefinition Width="25" />
                        <ColumnDefinition Width="25"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Login"
                               Grid.Column="0"
                               FontSize="15"
                               Foreground="Black"
                               VerticalAlignment="Center" 
                               Margin="10,0,0,0"/>
                    <Button x:Name="btnMin"
                            Grid.Column="1" 
                            Background="Transparent"
                            BorderBrush="Transparent" 
                            Click="btnMin_Click"
                            Cursor="Hand"
                            ToolTip="Minimize">
                        <Image Source="/Images/window-minimize.png" 
                               Width="12" 
                               Height="12" 
                               VerticalAlignment="Top" 
                               HorizontalAlignment="Center"/>
                    </Button>
                    <Button x:Name="btnMax"
                            Grid.Column="2" 
                            Background="Transparent"
                            BorderBrush="Transparent" 
                            Click="btnMax_Click"
                            Cursor="Hand"
                            ToolTip="Maximize/Restore">
                        <Image x:Name="btnMaxImage"
                               Source="/Images/window-maximize.png" 
                               Width="12" 
                               Height="12" 
                               VerticalAlignment="Top" 
                               HorizontalAlignment="Center"/>
                    </Button>
                    <Button x:Name="btnClose"
                            Grid.Column="3" 
                            Background="Transparent"
                            BorderBrush="Transparent" 
                            Click="btnClose_Click"
                            Cursor="Hand"
                            ToolTip="Close">
                        <Image Source="/Images/cross.png" 
                               Width="12" 
                               Height="12" 
                               VerticalAlignment="Top" 
                               HorizontalAlignment="Center"/>
                    </Button>

                </Grid>
                <StackPanel Grid.Row="1"
                            Width="250"
                            Orientation="Vertical"
                            Margin="0,35,0,0">
                    <Image Source="/Images/logo.png" 
                           Height="110" 
                           />
                    <TextBlock Text="Username:" 
                               Foreground="White" 
                               Margin="0,20,0,5"
                               FontSize="14"
                               FontWeight="Medium"/>
                    <TextBox x:Name="txtUsername"
                             Text="{Binding Username,UpdateSourceTrigger=PropertyChanged}"
                             FontSize ="13"
                             FontWeight="Medium"
                             Foreground="White" 
                             CaretBrush="LightGray"
                             BorderBrush="#555" 
                             BorderThickness="0,0,0,1"
                             Height="28"
                             VerticalContentAlignment="Center"
                             Margin="0,5,0,0">
                        <TextBox.Background>
                            <ImageBrush ImageSource="/Images/user.png"
                                        Stretch="None"
                                        AlignmentX="Left"/>

                        </TextBox.Background>
                    </TextBox>

                    <TextBlock Text="Username:" 
                               Foreground="White" 
                               Margin="0,20,0,5"
                               FontSize="14"
                               FontWeight="Medium"/>
                    <Grid>
                      <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition Height="Auto"/>
                      </Grid.RowDefinitions>

                      <!-- stacked controls: PasswordBox (default) and TextBox (shown when checked) -->
                      <Grid Grid.Row="0">
                            <PasswordBox x:Name="txtPassword"
                                     FontSize="13"
                                     FontWeight="Medium"
                                     Foreground="White"
                                     
                                     CaretBrush="LightGray"
                                     BorderBrush="#555"
                                     BorderThickness="0,0,0,1"
                                     Height="28"
                                     VerticalContentAlignment="Center"
                                     Margin="0,5,0,0"
                                     >
                                <PasswordBox.Background>
                                    <ImageBrush ImageSource="/Images/key-solid.png"
                                                Stretch="None"
                                                AlignmentX="Left"/>
                                </PasswordBox.Background>

                            </PasswordBox>
                            <TextBox x:Name="txtPasswordVisible"
                                 Visibility="Collapsed"
                                 FontSize="13"
                                 FontWeight="Medium"
                                 Foreground="White"
                                 Background="Transparent"
                                 CaretBrush="LightGray"
                                 BorderBrush="#555"
                                 BorderThickness="0,0,0,1"
                                 Height="28"
                                 VerticalContentAlignment="Center"
                                 Margin="0,5,0,0"
                                 />
                      </Grid>

                      <!-- show password toggle placed below the box -->
                      <CheckBox x:Name="chkShowPassword"
                                Grid.Row="1"
                                Content="Show password"
                                Foreground="White"
                                Margin="0,6,0,0"
                                Checked="chkShowPassword_Checked"
                                Unchecked="chkShowPassword_Unchecked"/>
                    </Grid>
                    <!-- Login button (rounded) -->
                    <Button x:Name="btnLogin"
                            Content="Login"
                            Height="36"
                            Margin="0,40,0,0"
                            Background="#FFEB9015"
                            Foreground="Black"
                            FontWeight="Bold"
                            BorderThickness="0"
                            HorizontalAlignment="Stretch"
                            Command="{Binding LoginCommand}"
                            CommandParameter="{Binding ElementName=txtPassword}"
                            >
                      <Button.Template>
                        <ControlTemplate TargetType="Button">
                          <Border Background="{TemplateBinding Background}"
                                  CornerRadius="18"
                                  SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                          </Border>
                        </ControlTemplate>
                      </Button.Template>
                    </Button>

                    <!-- Forgot password link -->
                    <TextBlock HorizontalAlignment="Right"
                               Margin="0,8,0,0"
                               Foreground="White">
                        <Hyperlink 
                                 Foreground="LightGray"
                                 TextDecorations="Underline">
                                  Forgot password?
                      </Hyperlink>      
                    </TextBlock>

                    <TextBlock Text="{Binding StatusMessage}" Foreground="White" HorizontalAlignment="Center" Margin="0,10,0,0" />


                </StackPanel>

            </Grid>
            

    </Border>
    </Border>

    
</Window>
