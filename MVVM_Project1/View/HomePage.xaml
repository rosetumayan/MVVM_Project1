<Window x:Class="MVVM_Project1.View.HomePage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MVVM_Project1.View"
        x:Name="ThisWindow"
        WindowStyle="None"
        WindowStartupLocation="CenterScreen"
        MouseDown="Window_MouseDown"
        mc:Ignorable="d"
        Title="HomePage" Height="450" Width="800">
    
        <Border CornerRadius="10">
            <Border.Background>
                <ImageBrush ImageSource="\Images\background.jpg" />

            </Border.Background>


            <Border CornerRadius="10"
                    BorderThickness="3"
                    Opacity="0.90">
                <Border.BorderBrush>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="LightGray" Offset="0.0" />
                        <GradientStop Color="Black" Offset="0.75" />
                        <GradientStop Color="Gray" Offset="1.0" />
                    </LinearGradientBrush>
                </Border.BorderBrush>
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="Black" Offset="0.10" />
                    </LinearGradientBrush>
                </Border.Background>

            <DockPanel>
                


                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="30" />
                        <RowDefinition Height="50" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Rectangle Grid.Row="0" Fill="White" Opacity="0.50" />

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                           
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="25" />
                            <ColumnDefinition Width="25" />
                            <ColumnDefinition Width="25"/>
                        </Grid.ColumnDefinitions>
                        
                        
                        <Menu Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Left" Background="Transparent">

                            <MenuItem Header="Home" 
                                FontWeight="Heavy"
                                FontFamily="Segoe UI"
                                Foreground="Black"
                                Command="{Binding ShowHomeCommand}"/>

                            <MenuItem Header="My Account" >
                                <MenuItem Header="My Profile" Command="{Binding MyProfileCommand}"/>
                                <Separator />
                                <MenuItem Header="Change Password" Command="{Binding ChangePasswordCommand}"/>
                            </MenuItem>

                            <MenuItem Header="Admin">
                                <MenuItem Header="Manage Users" Command="{Binding ManageUsersCommand}"/>
                                <MenuItem Header="Reports and Summary" Command="{Binding ManageReportsCommand}"/>
                            </MenuItem>

                            <MenuItem Header="Logout" Command="{Binding LogoutCommand}"/>

                        </Menu>

                        <Button 
                            Grid.Column="1" 
                            Background="Transparent"
                            BorderBrush="Transparent" 
                            Command="{Binding ButtonMinimizedCommand}"
                            Cursor="Hand"
                            ToolTip="Minimize">
                            <Image Source="/Images/window-minimize.png" 
                                   Width="12" 
                                   Height="12" 
                                   VerticalAlignment="Top" 
                                   HorizontalAlignment="Center"/>
                        </Button>
                        <Button x:Name="btnMax"
                            Grid.Column="2" 
                            Background="Transparent"
                            BorderBrush="Transparent" 
                            Command="{Binding ButtonMaximizedCommand}"
                            CommandParameter="{Binding ElementName=btnMaxImage}"
                            Cursor="Hand"
                            ToolTip="Maximize/Restore">
                            <Image x:Name="btnMaxImage"
                               Source="/Images/window-maximize.png" 
                               Width="12" 
                               Height="12" 
                               VerticalAlignment="Top" 
                               HorizontalAlignment="Center"/>       
                        </Button>
                        <Button x:Name="btnClose"
                            Grid.Column="3" 
                            Background="Transparent"
                            BorderBrush="Transparent" 
                            Command="{Binding ButtonCloseCommand}"
                            Cursor="Hand"
                            ToolTip="Close">
                            <Image Source="/Images/cross.png" 
                                   Width="12" 
                                   Height="12" 
                                   VerticalAlignment="Top" 
                                   HorizontalAlignment="Center"/>       
                        </Button>


                    </Grid>

                    <TextBlock Grid.Row="1" Text="{Binding LoggedInUser.Username, StringFormat='Welcome, {0}!'}" 
                               FontSize="24" 
                               FontWeight="Bold" 
                               Foreground="White" 
                               HorizontalAlignment="Center" 
                               VerticalAlignment="Center" />
                    <Grid Grid.Row="2">
                        
                        <Grid.ColumnDefinitions >
                            <ColumnDefinition Width="550" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="White" 
                            Opacity="0.85" 
                            Margin="10" 
                            CornerRadius="10">
                            <ListView Margin="10" ItemsSource="{Binding LostItemsList}"
                                      SelectedItem="{Binding SelectedLostItems}">
                                <ListView.View>
                                    <GridView >
                                        <GridViewColumn Header="Item Name" DisplayMemberBinding="{Binding ItemName}" Width="100"/>
                                        <GridViewColumn Header="Description" DisplayMemberBinding="{Binding Description}" Width="150"/>
                                        <GridViewColumn Header="Location" DisplayMemberBinding="{Binding Location}" Width="100"/>
                                        <GridViewColumn Header="Date Reported" DisplayMemberBinding="{Binding DateReported, StringFormat=d}" Width="100"/>
                                        <GridViewColumn Header="Status" DisplayMemberBinding="{Binding IsFound}" Width="50"/>
                                    </GridView>
                                </ListView.View>
                            </ListView>
                        </Border>
                        <Border Grid.Column="1" Background="White" 
                            Opacity="0.90" 
                            Margin="10" 
                            CornerRadius="10">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="45"/>
                                </Grid.RowDefinitions>
                                <StackPanel Grid.Row="0" Margin="10">
                                    <TextBlock Text="Report New Lost Item" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                                  
                                        <TextBlock Text="Name:"/>
                                        <TextBox Text="{Binding newLostItems.ItemName}" Margin="0,5,0,10"/>
                                        <TextBlock Text="Description:"/>
                                        <TextBox Text="{Binding newLostItems.Description}" Margin="0,5,0,10"/>
                                        <TextBlock Text="Location:"/>
                                        <TextBox Text="{Binding newLostItems.Location}" Margin="0,5,0,10"/>
                                        <TextBlock Text="Date Reported:"/>
                                        <TextBox Text="{Binding newLostItems.DateReported}" Margin="0,5,0,10"/>
                                        <CheckBox Content="Status" IsChecked="{Binding newLostItems.IsFound}" Margin="0,0,10,0"/>
                                        
                                 
                                </StackPanel>
                                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center">
                                    
                                        <Button Content="Save" Command="{Binding SaveCommand}" Margin="10"/>
                                            <Button Content="Delete" Command="{Binding DeleteCommand}" Margin="10"/>
                                         <Button Content="Clear" Command="{Binding ClearCommand}" Margin="10"/> 


                                </StackPanel>

                            </Grid>
                            
                        </Border>
                    </Grid>
                    
                </Grid>

            </DockPanel>
        </Border>
        </Border>
    

</Window>
