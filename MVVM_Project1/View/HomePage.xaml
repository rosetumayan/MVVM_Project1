<Window x:Class="MVVM_Project1.View.HomePage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MVVM_Project1.View"
        x:Name="ThisWindow"
        mc:Ignorable="d"
        Title="HomePage" Height="450" Width="800">
    <DockPanel>
        <Menu DockPanel.Dock="Top" Height="25">

            <MenuItem Header="_File">
                <MenuItem Header="_Logout" Command="{Binding LogoutCommand}"/>
                <Separator />
                <MenuItem Header="E_xit" Command="{Binding ExitCommand}"/>
            </MenuItem>

            <MenuItem Header="_Items">
                <MenuItem Header="Report _Lost Item" Command="{Binding ReportLostCommand}"/>
                <MenuItem Header="View _Found Items" Command="{Binding ViewFoundItemsCommand}"/>
            </MenuItem>

        </Menu>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="50"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Button Content="Add New Lost Item" HorizontalAlignment="Right" Margin="10" Command="{Binding AddNewLostItemCommand}" CommandParameter="{Binding ElementName=ThisWindow}"/>

            <StackPanel Grid.Row="1" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="86,63,0,0">

                <TextBlock Text="{Binding CurrentUser.Username, StringFormat = 'Welcome to the main Home Page {0}!'}" HorizontalAlignment="Center"  FontSize="24" Margin="0,0,0,10" />
                <Grid Width="600" Height="200" Margin="10,10,10,10">

                    <DataGrid ItemsSource="{Binding LostItemsList}" 
                      AutoGenerateColumns="True" 
                      CanUserAddRows="False" 
                      AlternatingRowBackground="LightGray" />

                </Grid>
            </StackPanel>
        </Grid>
    </DockPanel>

</Window>
