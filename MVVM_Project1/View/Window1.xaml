<Window x:Class="MVVM_Project1.View.Window1"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MVVM_Project1.View"
        x:Name="ThisWindow"
        mc:Ignorable="d"
        Title="Window1" Height="450" Width="800">
    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="Enter item name:" FontSize="16" Margin="0,0,0,10" />
            <TextBox Height="30" Width="200" Margin="0,0,0,10" Text="{Binding NewLostItem.ItemName, UpdateSourceTrigger=PropertyChanged}" />
            <TextBlock Text="Enter item description:" FontSize="16" Margin="0,0,0,10" />
            <TextBox Height="30" Width="200" Margin="0,0,0,10" Text="{Binding NewLostItem.Description, UpdateSourceTrigger=PropertyChanged}" />

            <Button Content="Save" Width="100" Command="{Binding SaveCommand}" CommandParameter="{Binding ElementName=ThisWindow}"/>

        </StackPanel>
    </Grid>
</Window>
